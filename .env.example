# Sentinel environment variables. Copy to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored). All of these are SERVER-ONLY
# secrets — a security product must never leak its keys to the client.

# --- Supabase Postgres (used purely as hosted Postgres + table viewer via Prisma) ---
# Get both from: Supabase project -> Connect -> ORMs tab -> Prisma.
# DATABASE_URL = pooled connection (port 6543, host contains "pooler"), used by the app at runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = direct connection (port 5432), used by Prisma for migrations and seeding.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Google Gemini (server-side only; Scam Check + plain-language explanations) ---
# Get from: https://aistudio.google.com/ -> Get API key
GEMINI_API_KEY="your-gemini-api-key"
